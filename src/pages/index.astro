---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import NavBar from "../components/NavBar.astro";
import LiveTimer from "../components/LiveTimer.astro";
import TrustedLogos from "../components/TrustedLogos.astro";
import AgencyComparison from "../components/AgencyComparison.astro";
import SkuShowcase from "../components/SkuShowcase.astro";
import MethodologyPreview from "../components/MethodologyPreview.astro";
import CaseHighlights from "../components/CaseHighlights.astro";
import FAQ from "../components/FAQ.astro";
import FinalCTA from "../components/FinalCTA.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<BaseLayout
  title="Shipwright 船匠 · 14 天交付你的跨境电商 AI 工作流"
  description="别堆人，造船。跨境电商 DTC 的 AI 工作流定制团队。14 天硬交付 · 代码 100% 归你 · 透明定价 · BYOK。"
  path="/"
>
  <NavBar />

  <!-- Section 2: Hero (cascade stagger · Motion One spring · CineStream 居中风格) -->
  <section class="mx-auto max-w-[1400px] px-6 pb-20 pt-12 sm:pt-16" data-hero-stagger>
    <p
      class="mb-6 text-center font-mono uppercase hero-item"
      style="font-size:var(--text-overline);letter-spacing:var(--text-overline--letter-spacing);color:var(--accent);opacity:0"
    >
      For DTC Operators
    </p>

    <!-- 居中大号 headline · CineStream 风格 -->
    <h1
      class="mx-auto mb-6 max-w-5xl text-center font-bold tracking-tight hero-item"
      style="font-size:clamp(2.75rem,7vw,5rem);line-height:1.08;letter-spacing:-0.02em;color:var(--fg-display);opacity:0"
    >
      别堆人，造船。让跨境电商在 14 天内拥有
      <span style="color:var(--accent);font-weight:800">Vibecoding Pod</span>
    </h1>

    <p
      class="mx-auto mb-10 max-w-2xl text-center font-mono hero-item"
      style="font-size:clamp(1.125rem,2vw,1.375rem);line-height:1.6;color:var(--fg-muted);opacity:0"
    >
      Don't hire. Ship. · 14 天交付一个可量产的 AI 工作流 · 代码 100% 归你 · 支持 BYOK
    </p>

    <!-- 双 CTA · 居中 pill 按钮 (参考 CineStream) -->
    <div class="mb-16 flex flex-wrap items-center justify-center gap-3 hero-item" style="opacity:0">
      <a
        href="/pilot-pod"
        class="inline-flex h-12 items-center rounded-[var(--radius-pill)] px-7 text-sm font-semibold transition hover:brightness-95"
        style="background:var(--accent);color:var(--accent-fg);box-shadow:0 10px 30px rgba(254,242,151,0.2)"
      >
        Get started · Pilot Pod
      </a>
      <a
        href="/how"
        class="inline-flex h-12 items-center rounded-[var(--radius-pill)] border px-7 text-sm font-medium transition hover:bg-[var(--bg-muted)]"
        style="border-color:var(--border-strong);color:var(--fg-display)"
      >
        Live Timer · 14 天
      </a>
    </div>

    <!-- 14 天 Live Timer · 居中大卡片 · 替代右侧 sticky (对齐 CineStream 大号 hero card) -->
    <div class="mx-auto max-w-4xl hero-item" style="opacity:0">
      <LiveTimer />
    </div>
  </section>

  <!-- Hero cascade stagger · Motion One spring(100,20) -->
  <script>
    import { animate, stagger } from "motion";

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const items = document.querySelectorAll("[data-hero-stagger] .hero-item");

    if (reduced) {
      items.forEach((el) => ((el as HTMLElement).style.opacity = "1"));
    } else {
      animate(
        items,
        { opacity: [0, 1], y: [16, 0] },
        {
          delay: stagger(0.08, { start: 0.1 }),
          duration: 0.7,
          type: "spring",
          stiffness: 100,
          damping: 20,
        }
      );
    }
  </script>

  <!-- Section 4: 客户信任墙 -->
  <TrustedLogos />

  <!-- Section 5: 不像 Agency 宣言 -->
  <AgencyComparison />

  <!-- Section 6: 4 SKU 横排 -->
  <SkuShowcase />

  <!-- Section 7: 14 天方法论预览 -->
  <MethodologyPreview />

  <!-- Section 8: 案例精选 -->
  <CaseHighlights />

  <!-- Section 9: FAQ -->
  <FAQ />

  <!-- Section 10: Final CTA -->
  <FinalCTA />

  <!-- Footer -->
  <SiteFooter />
</BaseLayout>
