---
export const prerender = true;
import BaseLayout from "../../layouts/BaseLayout.astro";
import NavBar from "../../components/NavBar.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import LegalLayout from "../../components/LegalLayout.astro";
---

<BaseLayout
  title="ICP 备案信息 · Shipwright 船匠"
  description="Shipwright 网站 ICP 备案信息与公安备案信息（中国大陆合规展示）"
  path="/legal/icp"
>
  <NavBar />

  <LegalLayout
    title="ICP 备案信息"
    effectiveDate="2026-04-22"
    lastUpdated="2026-04-22"
  >
    <div
      class="my-6 rounded-[var(--radius-md)] border-l-4 p-4"
      style="background:var(--color-warning-50);border-color:var(--color-warning-500);color:var(--color-warning-700)"
    >
      <strong>状态说明</strong>: 本站正在办理 ICP 备案中 · 备案主体已提交阿里云管局审核 · 预计审核周期 7-20 个工作日 · 备案完成后本页显示正式备案号。
      <br />在此期间, 中国大陆用户可访问 <code>shipwright.co</code> 海外灰度版。
    </div>

    <h2>1. ICP 备案信息</h2>
    <table class="my-4 w-full border-collapse text-sm">
      <tbody>
        <tr>
          <td class="border-b py-2 pr-4 font-semibold" style="border-color:var(--border-default);color:var(--fg-display);width:10rem">网站名称</td>
          <td class="border-b py-2" style="border-color:var(--border-default)">Shipwright 船匠</td>
        </tr>
        <tr>
          <td class="border-b py-2 pr-4 font-semibold" style="border-color:var(--border-default);color:var(--fg-display)">网站域名</td>
          <td class="border-b py-2" style="border-color:var(--border-default)"><code>shipwright.cn</code> · <code>shipwright.co</code></td>
        </tr>
        <tr>
          <td class="border-b py-2 pr-4 font-semibold" style="border-color:var(--border-default);color:var(--fg-display)">备案主体</td>
          <td class="border-b py-2" style="border-color:var(--border-default)">上海船匠科技有限公司</td>
        </tr>
        <tr>
          <td class="border-b py-2 pr-4 font-semibold" style="border-color:var(--border-default);color:var(--fg-display)">主体性质</td>
          <td class="border-b py-2" style="border-color:var(--border-default)">企业</td>
        </tr>
        <tr>
          <td class="border-b py-2 pr-4 font-semibold" style="border-color:var(--border-default);color:var(--fg-display)">ICP 备案号</td>
          <td class="border-b py-2" style="border-color:var(--border-default);color:var(--fg-muted)">沪 ICP 备 备案申请中</td>
        </tr>
        <tr>
          <td class="border-b py-2 pr-4 font-semibold" style="border-color:var(--border-default);color:var(--fg-display)">备案审核单位</td>
          <td class="border-b py-2" style="border-color:var(--border-default)">上海市通信管理局</td>
        </tr>
        <tr>
          <td class="border-b py-2 pr-4 font-semibold" style="border-color:var(--border-default);color:var(--fg-display)">公安备案号</td>
          <td class="border-b py-2" style="border-color:var(--border-default);color:var(--fg-muted)">沪公网安备 审核中</td>
        </tr>
        <tr>
          <td class="py-2 pr-4 font-semibold" style="color:var(--fg-display)">网站负责人</td>
          <td class="py-2">技术负责人 · 联系邮箱 <code>tech@shipwright.co</code></td>
        </tr>
      </tbody>
    </table>

    <h2>2. 服务器与 CDN 信息</h2>
    <ul>
      <li><strong>国内主站 (shipwright.cn)</strong>: 阿里云 OSS + CDN (杭州 / 张家口 双 region)</li>
      <li><strong>海外主站 (shipwright.co)</strong>: Cloudflare Pages + Cloudflare CDN (全球分发)</li>
      <li><strong>API 服务</strong>: 阿里云函数计算 FC (Node 20 Runtime, 杭州)</li>
      <li><strong>数据库</strong>: 阿里云 RDS PostgreSQL (杭州) + Neon 海外副本 (Phase 2 启用)</li>
    </ul>

    <h2>3. 法定变更记录</h2>
    <p>本表记录备案信息的重大变更。</p>
    <table class="my-4 w-full border-collapse text-sm">
      <thead>
        <tr style="background:var(--bg-muted)">
          <th class="border-b px-3 py-2 text-left font-mono text-xs uppercase tracking-[0.08em]" style="border-color:var(--border-default);color:var(--fg-muted)">日期</th>
          <th class="border-b px-3 py-2 text-left font-mono text-xs uppercase tracking-[0.08em]" style="border-color:var(--border-default);color:var(--fg-muted)">变更内容</th>
          <th class="border-b px-3 py-2 text-left font-mono text-xs uppercase tracking-[0.08em]" style="border-color:var(--border-default);color:var(--fg-muted)">备案号</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="px-3 py-2" style="color:var(--fg-default)">2026-04-22</td>
          <td class="px-3 py-2" style="color:var(--fg-default)">首次提交备案申请</td>
          <td class="px-3 py-2" style="color:var(--fg-muted)">—</td>
        </tr>
      </tbody>
    </table>

    <h2>4. 合规声明</h2>
    <p>
      Shipwright 严格遵守《中华人民共和国网络安全法》《中华人民共和国数据安全法》《中华人民共和国个人信息保护法》及相关法律法规。
      本站不提供任何违反中国法律法规的内容或服务。
    </p>

    <h2>5. 联系方式</h2>
    <ul>
      <li><strong>备案相关问题</strong>: <code>legal@shipwright.co</code></li>
      <li><strong>安全事件举报</strong>: <code>security@shipwright.co</code></li>
      <li><strong>违法不良信息举报</strong>: 12377 (网信办) / <code>report@shipwright.co</code></li>
    </ul>
  </LegalLayout>

  <SiteFooter />
</BaseLayout>
