---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import NavBar from "../components/NavBar.astro";
import SiteFooter from "../components/SiteFooter.astro";
import LeadForm from "../components/LeadForm.astro";

const contactChannels = [
  { label: "邮箱", value: "hello@aioars.com", icon: "mail" },
  { label: "飞书", value: "@船匠 AiOars", icon: "lark" },
  { label: "微信", value: "添加见右下角 chat", icon: "wechat" },
  { label: "LinkedIn", value: "AiOars Inc.", icon: "linkedin" },
];

// 判断是否工作时间（客户端会实时更新，SSG 先渲染默认态）
---

<BaseLayout
  title="联系我们 · 30 分钟免费 AI 诊断 · AiOars 船匠"
  description="留下联系方式, 我们 2 小时内回复. 30 分钟免费 AI 诊断 · 告诉你哪个 SKU 最值得先造 · 零承诺."
  path="/contact"
>
  <NavBar />

  <main class="mx-auto max-w-[1100px] px-6 pb-20 pt-16 sm:pt-24">
    <div class="grid gap-12 lg:grid-cols-[1.2fr_1fr]">
      <!-- 左: 叙事 -->
      <div>
        <p
          class="mb-4 font-mono uppercase"
          style="font-size:var(--text-overline);letter-spacing:var(--text-overline--letter-spacing);color:var(--color-signal-600)"
        >
          Free · 30 min · no commitment
        </p>

        <h1
          class="mb-4 font-semibold"
          style="font-size:clamp(2.25rem,5vw,3.5rem);line-height:1.1;letter-spacing:-0.02em;color:var(--fg-display)"
        >
          30 分钟诊断 · 零承诺。
        </h1>

        <p
          class="mb-8 max-w-xl"
          style="font-size:var(--text-body-lg);color:var(--fg-default)"
        >
          告诉我们你的业务场景 · 我们告诉你哪个 SKU 最值得先造, 或者用 ChatGPT Team + Zapier
          自助就够了不用找我们。<strong style="color:var(--fg-display)">聊完你再决定</strong>。
        </p>

        <!-- 预期 -->
        <div
          class="mb-8 rounded-[var(--radius-md)] border-l-2 p-4"
          style="background:var(--bg-muted);border-color:var(--color-signal-500)"
        >
          <p class="mb-2 text-sm font-semibold" style="color:var(--fg-display)">
            这 30 分钟里我们会聊:
          </p>
          <ul class="space-y-1 text-sm" style="color:var(--fg-default)">
            <li>• 你现在每天花时间在哪件事上最多</li>
            <li>• 哪个场景用 AI 最有杠杆 (不一定是我们卖的)</li>
            <li>• 预估的 ROI + 投入产出比</li>
            <li>• 如果合适, 走 Pilot Pod (¥12.8K / 5 天) 试一下</li>
            <li>• 如果不合适, 推荐哪些工具自助就能搞定</li>
          </ul>
        </div>

        <!-- 多渠道联系方式 -->
        <div>
          <p
            class="mb-3 font-mono text-xs uppercase tracking-[0.08em]"
            style="color:var(--fg-muted)"
          >
            或者直接找我们
          </p>
          <ul class="grid grid-cols-2 gap-3">
            {contactChannels.map((c) => (
              <li
                class="rounded-[var(--radius-md)] border p-3"
                style="background:var(--bg-card);border-color:var(--border-default)"
              >
                <div
                  class="mb-1 font-mono text-[10px] uppercase tracking-[0.08em]"
                  style="color:var(--fg-muted)"
                >
                  {c.label}
                </div>
                <div class="font-medium" style="color:var(--fg-display)">
                  {c.value}
                </div>
              </li>
            ))}
          </ul>
        </div>

        <!-- 工作时间 indicator -->
        <div
          class="mt-6 inline-flex items-center gap-2 rounded-full border px-3 py-1.5 font-mono text-xs"
          style="border-color:var(--border-default);color:var(--fg-muted)"
          data-working-hours
        >
          <span
            class="inline-block h-2 w-2 rounded-full"
            style="background:var(--color-success-500)"
            data-working-dot
          ></span>
          <span data-working-label>工作时间内 · 2h 内回复</span>
        </div>
      </div>

      <!-- 右: 表单 -->
      <div
        class="rounded-[var(--radius-lg)] border p-6 sm:p-8 lg:sticky lg:top-24 lg:self-start"
        style="background:var(--bg-card);border-color:var(--border-default);box-shadow:var(--shadow-lg)"
      >
        <h2 class="mb-1 text-xl font-semibold" style="color:var(--fg-display)">
          留下信息 · 2h 内回你
        </h2>
        <p class="mb-6 text-sm" style="color:var(--fg-muted)">
          7 个字段 · 必填 4 个 · 全部可选填到备注里
        </p>
        <LeadForm />
      </div>
    </div>
  </main>

  <SiteFooter />
</BaseLayout>

<script is:inline>
  // 工作时间判定: 工作日 09:00-22:00 CST
  (() => {
    const hoursEl = document.querySelector("[data-working-hours]");
    if (!hoursEl) return;
    const dot = hoursEl.querySelector("[data-working-dot]");
    const label = hoursEl.querySelector("[data-working-label]");

    const now = new Date();
    const beijingOffset = 8 * 60; // CST UTC+8
    const local = new Date(now.getTime() + (beijingOffset + now.getTimezoneOffset()) * 60000);
    const hour = local.getHours();
    const day = local.getDay(); // 0 = Sunday
    const isWeekend = day === 0 || day === 6;
    const isWorking = !isWeekend && hour >= 9 && hour < 22;

    if (isWorking) {
      dot.style.background = "var(--color-success-500)";
      label.textContent = "工作时间内 · 2h 内回复";
    } else {
      dot.style.background = "var(--color-warning-500)";
      label.textContent = isWeekend ? "周末 · 下周一 9:00 回复" : "非工作时间 · 次日 9:00 回复";
    }
  })();
</script>
