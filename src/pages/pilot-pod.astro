---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import NavBar from "../components/NavBar.astro";
import SiteFooter from "../components/SiteFooter.astro";
import FinalCTA from "../components/FinalCTA.astro";

const scenarios = [
  {
    tag: "V-CS",
    title: "Instagram DM / Shopify Inbox 自动回复",
    typical: "响应时长 >12h · 差评率 >3%",
    result: "DM 自动解决率 60%+ · 响应时长降到 10 分钟级",
  },
  {
    tag: "V-SEO",
    title: "Amazon / Shopify listing 批量生成 + 翻译",
    typical: "月上新 <30 条 · 人工写 listing 跟不上",
    result: "产能 3x · 平均生成时间从 45 分钟降到 3 分钟",
  },
  {
    tag: "V-CONTENT",
    title: "小红书 / TikTok 评论监控 + 品牌声量预警",
    typical: "差评漏掉 >24h · 无主动监控",
    result: "差评 5 分钟内飞书推送 · 竞品声量日报自动生成",
  },
];

const deliverables = [
  "1 个 Claude Code 部署的 AI agent (跑在客户 Cloudflare Worker 或我们托管)",
  "1 个平台集成 (Shopify Admin API / Meta Graph API / 小红书开放接口 三选一)",
  "1 份 SOP 文档 (何时触发 / 失败兜底 / 人工接管阈值)",
  "1 次 1 小时客户培训 (录屏 + 操作手册)",
  "30 天 bug 保修",
];

const notIncluded = [
  "多渠道协同",
  "A/B test",
  "数据看板",
  "模型微调",
  "多语言",
];
---

<BaseLayout
  title="Pilot Pod / 试航舱 ¥12,800 · 5 天试错 · Shipwright"
  description="5 天 ¥12,800 跑通一个窄 AI 场景. 证明 ROI 再决定要不要造整艘船. 60% 一次性抵扣升级 Vibecoding Pod (¥58K). 30 天 bug 保修."
  path="/pilot-pod"
>
  <NavBar />

  <main>
    <!-- Hero -->
    <section class="mx-auto max-w-[1200px] px-6 pb-12 pt-16 sm:pt-24">
      <p
        class="mb-4 font-mono uppercase"
        style="font-size:var(--text-overline);letter-spacing:var(--text-overline--letter-spacing);color:var(--color-signal-600)"
      >
        Pilot Pod · 试航舱
      </p>
      <h1
        class="mb-4 font-semibold"
        style="font-size:clamp(2.5rem,6vw,4rem);line-height:1.1;letter-spacing:-0.02em;color:var(--fg-display)"
      >
        先试航，再造船。
      </h1>
      <p
        class="mb-10 max-w-2xl"
        style="font-size:var(--text-body-lg);color:var(--fg-default)"
      >
        用 ¥12,800 / 5 天跑通一个窄 AI 场景, 证明 ROI 再决定要不要造整艘船。
        <strong style="color:var(--fg-display)">60% 一次性抵扣</strong> 升级 Vibecoding Pod (¥58K)。
      </p>

      <!-- 核心数字 + CTA -->
      <div
        class="mb-6 grid gap-6 rounded-[var(--radius-lg)] border p-6 sm:grid-cols-[1.5fr_1fr_auto] sm:items-center"
        style="background:var(--bg-card);border-color:var(--border-default);box-shadow:var(--shadow-md)"
      >
        <div>
          <div
            class="tabular-nums font-bold"
            style="font-size:clamp(2rem,4vw,2.75rem);color:var(--fg-display)"
          >
            ¥12,800
            <span class="ml-1 font-mono text-sm font-normal" style="color:var(--fg-muted)">
              / $2,400
            </span>
          </div>
          <div class="text-sm" style="color:var(--fg-muted)">
            一次性 · 5 个工作日交付 · 30 天 bug 保修
          </div>
        </div>
        <div class="text-sm">
          <div class="mb-1 font-mono text-[11px] uppercase tracking-[0.08em]" style="color:var(--color-signal-600)">
            升级钩子
          </div>
          <div style="color:var(--fg-default)">
            30 天内 60% 折抵 Vibecoding Pod 升级
            <br />= 再付 ¥50,320 起就能开 14 天主推款
          </div>
        </div>
        <a
          href="/contact?sku=pilot-pod"
          class="inline-flex h-12 items-center justify-center rounded-[var(--radius-md)] px-6 text-sm font-semibold transition hover:brightness-110"
          style="background:var(--color-signal-500);color:var(--color-canvas-50);box-shadow:var(--shadow-sm)"
        >
          开始 Pilot Pod →
        </a>
      </div>

      <p class="font-mono text-xs" style="color:var(--fg-muted)">
        目标客户: 月 GMV ¥50K-¥500K · 3-10 人团队 · 没用过 AI agent 但用过 ChatGPT 写文案 · 老板还在拉群回客服
      </p>
    </section>

    <!-- 3 个窄场景选择 -->
    <section
      class="border-y py-16"
      style="background:var(--bg-section);border-color:var(--border-default)"
    >
      <div class="mx-auto max-w-[1100px] px-6">
        <p
          class="mb-3 font-mono uppercase"
          style="font-size:var(--text-overline);letter-spacing:var(--text-overline--letter-spacing);color:var(--color-signal-600)"
        >
          Pick one scenario · we ship it in 5 days
        </p>
        <h2
          class="mb-8 font-semibold"
          style="font-size:clamp(1.5rem,3.5vw,2rem);line-height:1.15;color:var(--fg-display)"
        >
          选一个窄场景 · 不贪多
        </h2>

        <div class="grid gap-4 md:grid-cols-3">
          {scenarios.map((s, i) => (
            <div
              class="rounded-[var(--radius-lg)] border p-6"
              style="background:var(--bg-card);border-color:var(--border-default)"
            >
              <div
                class="mb-3 inline-flex items-center gap-2"
              >
                <span
                  class="rounded-full px-2 py-0.5 font-mono text-[10px] font-bold uppercase tracking-[0.1em]"
                  style="background:var(--color-primary-50);color:var(--color-primary-700)"
                >
                  {s.tag}
                </span>
                <span class="font-mono text-[10px]" style="color:var(--fg-muted)">
                  {String(i + 1).padStart(2, "0")} / 03
                </span>
              </div>
              <h3 class="mb-3 text-base font-semibold" style="color:var(--fg-display)">
                {s.title}
              </h3>
              <div class="mb-3 text-xs" style="color:var(--fg-muted)">
                <span class="font-mono uppercase tracking-[0.08em]">Before:</span> {s.typical}
              </div>
              <div class="text-xs" style="color:var(--color-success-700)">
                <span class="font-mono uppercase tracking-[0.08em]">After:</span> {s.result}
              </div>
            </div>
          ))}
        </div>

        <p
          class="mt-6 rounded-[var(--radius-md)] border-l-2 p-4 text-sm"
          style="background:var(--bg-card);border-color:var(--color-signal-500);color:var(--fg-muted)"
        >
          <strong style="color:var(--fg-display)">不在这 3 个场景里?</strong>
          我们也能 5 天做, 但 ROI 保证相对弱。建议走 Vibecoding Pod (14 天) 做定制场景。
        </p>
      </div>
    </section>

    <!-- 交付内容清单 -->
    <section class="mx-auto max-w-[1100px] px-6 py-16">
      <p
        class="mb-3 font-mono uppercase"
        style="font-size:var(--text-overline);letter-spacing:var(--text-overline--letter-spacing);color:var(--color-signal-600)"
      >
        What you get
      </p>
      <h2
        class="mb-8 font-semibold"
        style="font-size:clamp(1.5rem,3.5vw,2rem);line-height:1.15;color:var(--fg-display)"
      >
        5 天内交付给你的清单
      </h2>

      <div class="grid gap-8 md:grid-cols-2">
        <div>
          <h3
            class="mb-4 font-mono text-sm uppercase tracking-[0.08em]"
            style="color:var(--color-success-700)"
          >
            ✓ 包含
          </h3>
          <ul class="space-y-3">
            {deliverables.map((d, i) => (
              <li class="flex items-start gap-3">
                <span
                  class="mt-1 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full font-mono text-[10px] font-bold"
                  style="background:var(--color-success-50);color:var(--color-success-700)"
                >
                  {i + 1}
                </span>
                <span class="text-sm" style="color:var(--fg-default)">{d}</span>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h3
            class="mb-4 font-mono text-sm uppercase tracking-[0.08em]"
            style="color:var(--fg-muted)"
          >
            ✗ 不包含 (留给 Vibecoding Pod)
          </h3>
          <ul class="space-y-3">
            {notIncluded.map((n) => (
              <li class="flex items-start gap-3">
                <span
                  class="mt-1 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full font-mono text-[10px]"
                  style="background:var(--bg-muted);color:var(--fg-muted)"
                >
                  ×
                </span>
                <span class="text-sm" style="color:var(--fg-muted)">{n}</span>
              </li>
            ))}
          </ul>
          <p class="mt-4 text-xs" style="color:var(--fg-subtle)">
            如果你需要上面这些, 升级
            <a href="/vibecoding-pod" style="color:var(--color-signal-600);font-weight:600">Vibecoding Pod (14 天)</a>
            即可 · 60% 折抵 Pilot Pod 已付款
          </p>
        </div>
      </div>
    </section>

    <!-- 升级钩子可视化 -->
    <section
      class="border-y py-16"
      style="background:var(--bg-section);border-color:var(--border-default)"
    >
      <div class="mx-auto max-w-[900px] px-6">
        <p
          class="mb-3 font-mono uppercase"
          style="font-size:var(--text-overline);letter-spacing:var(--text-overline--letter-spacing);color:var(--color-signal-600)"
        >
          Upgrade path
        </p>
        <h2
          class="mb-6 font-semibold"
          style="font-size:clamp(1.5rem,3.5vw,2rem);line-height:1.15;color:var(--fg-display)"
        >
          Pilot 满意 · 60% 折抵升级全闭环
        </h2>

        <div
          class="rounded-[var(--radius-lg)] border p-6 font-mono text-sm"
          style="background:var(--color-cool-800);color:var(--color-canvas-100);border-color:var(--color-cool-700)"
        >
          <div class="mb-4" style="color:var(--color-cool-400)">
            # Pilot Pod 30 天内升级 Vibecoding Pod 的账单
          </div>
          <div class="space-y-1">
            <div class="flex justify-between">
              <span>已付 Pilot Pod</span>
              <span style="color:var(--color-cool-500)">¥12,800</span>
            </div>
            <div class="flex justify-between" style="color:var(--color-signal-400)">
              <span>× 60% 折抵比例</span>
              <span>−¥7,680</span>
            </div>
            <div class="flex justify-between">
              <span>Vibecoding Pod 标价</span>
              <span style="color:var(--color-cool-500)">¥58,000</span>
            </div>
            <div
              class="mt-3 flex justify-between border-t pt-3"
              style="border-color:var(--color-cool-700);color:var(--fg-display)"
            >
              <span class="font-bold">补差升级仅付</span>
              <span class="font-bold" style="color:var(--color-signal-400)">¥50,320</span>
            </div>
          </div>
        </div>

        <p class="mt-4 text-sm" style="color:var(--fg-muted)">
          如果 Pilot 的 agent 已经在跑 · 升级时我们把它 migrate 到 Vibecoding Pod 的架构里 · 不白做。
        </p>
      </div>
    </section>

    <FinalCTA />
  </main>

  <SiteFooter />
</BaseLayout>
