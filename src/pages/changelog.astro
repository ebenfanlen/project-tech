---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import NavBar from "../components/NavBar.astro";
import SiteFooter from "../components/SiteFooter.astro";
import FinalCTA from "../components/FinalCTA.astro";

// dogfooding 透明度: 网站自己的更新 + starter kits 更新 + 内部工具
const entries = [
  {
    date: "2026-04-23",
    tag: "shipwright.co",
    title: "Week 2 批量: 11 stub 转真页 + Blog + Playbooks + 5 场景页",
    items: [
      "新增 /blog + 首篇 pillar 《AI 驱动跨境电商 DTC 的 14 天 MVP 方法论》(2000+ 字)",
      "新增 /work + 3 个脱敏 case study (Lumesque V-CS / NordicNest V-SEO / VoltCraft Fleet)",
      "新增 /scenes + 5 个场景详情页 (V-CS / V-SEO / V-AD / V-CONTENT / V-OPS)",
      "新增 /products overview + GMV 决策树",
      "新增 /playbooks + 4 个 playbook metadata (邮箱 gate)",
      "/changelog 这页本身也是 dogfooding 证据",
    ],
    link: "https://github.com/shipwright-org/shipwright/commits",
  },
  {
    date: "2026-04-23",
    tag: "shipwright.co",
    title: "Week 1 Day 7: SEO + CI/CD + 交付报告",
    items: [
      "@astrojs/sitemap 集成 · 25 URL 自动生成 sitemap-index.xml",
      "robots.txt 含 Baidu/360/Sogou/Claude/GPT 友好声明",
      "llms.txt 新规范 · LLM-friendly 索引",
      "favicon.svg 重做 The Keel mark (auto dark mode)",
      "GitHub Actions: 阿里云 OSS/CDN + Cloudflare Pages 双分发 + 百度主动推送 hook",
      "docs/DELIVERY-2026-04-23.md 完整交付报告",
    ],
    link: "https://github.com/shipwright-org/shipwright/commit/db14b43",
  },
  {
    date: "2026-04-23",
    tag: "shipwright.co",
    title: "Week 1 Day 6: /about + 3 剩余 SKU + 4 Legal 真页",
    items: [
      "/about: 三人创始团队 + 4 价值观 + Dogfooding 证据",
      "/vibecoding-pod: 5 大场景 Before/After 数字",
      "/fleet-integration: 主控 Agent + 工具 Agent ASCII 架构图",
      "/crew-retainer: 3 档 Retainer + 对标自招工程师表",
      "/legal/terms /privacy /icp /sla 完整法律文本 (PIPL + GDPR)",
    ],
    link: "https://github.com/shipwright-org/shipwright/commit/77886ff",
  },
  {
    date: "2026-04-23",
    tag: "shipwright.co",
    title: "Week 1 Day 5: /pilot-pod + /contact + LeadForm Island",
    items: [
      "/pilot-pod: 5 天 ¥12,800 + 3 个窄场景 + 升级钩子 60% 折抵可视化",
      "/contact: 双栏 Hero + sticky LeadForm (7 字段最小集) + 工作时间 indicator",
      "LeadForm 提交到 localStorage mock (Week 2 Day 10 接真后端)",
      "PIPL 授权 checkbox 必勾",
    ],
    link: "https://github.com/shipwright-org/shipwright/commit/823a11a",
  },
  {
    date: "2026-04-23",
    tag: "shipwright.co",
    title: "Week 1 Day 4: /pricing 和 /how 真页面",
    items: [
      "/pricing: 4 SKU 详细卡片 + 三段式定价公式 (代码块样式) + BYOK 对比 + 对标压制竞品表",
      "/how: 完整 Day-by-Day 14 天 Timeline + 为什么能做到 4 理由 + 超期退款条款",
    ],
    link: "https://github.com/shipwright-org/shipwright/commit/5ec9eb7",
  },
  {
    date: "2026-04-23",
    tag: "shipwright.co",
    title: "Week 1 Day 3: 首页 10 section 补全",
    items: [
      "客户信任墙 (8 脱敏客户 + 3 动态计数 12/34/1840)",
      "'不像 Agency' 三列对比 (反 CC Strategic 打法)",
      "SkuShowcase 4 SKU 横排 (Vibecoding Pod 主推 ring)",
      "MethodologyPreview 6 节点 Timeline",
      "CaseHighlights 3 featured case",
      "FAQ 8 核心问答 (手风琴)",
      "FinalCTA + SiteFooter (4 栏 + Newsletter + 社交 + ICP)",
    ],
    link: "https://github.com/shipwright-org/shipwright/commit/92373c6",
  },
  {
    date: "2026-04-23",
    tag: "shipwright.co",
    title: "Week 1 Day 2: Dark 三态 + 中文字体 + pangu",
    items: [
      "Noto Sans SC/TC Variable 自托管 (HarmonyOS 开源等价)",
      "pangu.js 中英自动薄空格",
      "ThemeToggle 组件 · 三态循环 (light/dark/system)",
      "system 模式监听 prefers-color-scheme",
      "百度 applicable-device meta",
    ],
    link: "https://github.com/shipwright-org/shipwright/commit/e1ca0fa",
  },
  {
    date: "2026-04-23",
    tag: "shipwright.co",
    title: "Day 1: Astro 6 + Tailwind v4 骨架 + Hero + Dark Mode",
    items: [
      "Astro 6.1 + Tailwind v4 via @tailwindcss/vite",
      "Inter Variable + JetBrains Mono Variable 自托管",
      "50+ UI tokens 落 @theme (11 档 tonal × 3 主色)",
      "The Keel Logo 组件 · 2s 呼吸桅杆 CLI 光标",
      "NavBar (sticky backdrop-blur)",
      "Hero: 别堆人造船 + 双画像 CTA 分叉",
      "14 天 Live Timer Geek 证据块 (mock Case #047 Day 03/14)",
      "Dark Mode 底色 primary-900 不用纯黑",
      "prefers-reduced-motion 硬约束",
    ],
    link: "https://github.com/shipwright-org/shipwright/commit/b213e29",
  },
];

const tagColors: Record<string, string> = {
  "shipwright.co": "var(--color-signal-600)",
  "starter-kits": "var(--color-primary-600)",
  "seomachine-cn": "var(--color-info-500)",
};
---

<BaseLayout
  title="Changelog · 产品更新日志 · Shipwright 船匠"
  description="Shipwright 每周更新日志 · 官网 + starter kits + SEOMachine 本地化 fork · dogfooding 透明度 · 公开 Git 历史."
  path="/changelog"
>
  <NavBar />

  <main>
    <section class="mx-auto max-w-[900px] px-6 pb-10 pt-16 sm:pt-24">
      <p
        class="mb-4 font-mono uppercase"
        style="font-size:var(--text-overline);letter-spacing:var(--text-overline--letter-spacing);color:var(--color-signal-600)"
      >
        Changelog
      </p>
      <h1
        class="mb-4 font-semibold"
        style="font-size:clamp(2rem,4.5vw,3rem);line-height:1.15;letter-spacing:-0.02em;color:var(--fg-display)"
      >
        每周更新 · dogfooding 透明度
      </h1>
      <p
        class="mb-10 max-w-2xl"
        style="font-size:var(--text-body-lg);color:var(--fg-default)"
      >
        官网 (shipwright.co) · 5 大场景 starter kits · SEOMachine 本地化 fork · 三个仓库的每次更新.
        我们对客户承诺 14 天, 自己的产品也用同样方法在造。
      </p>

      <!-- 三个仓库快捷链接 -->
      <div class="mb-12 flex flex-wrap gap-3 font-mono text-xs">
        <a
          href="https://github.com/shipwright-org/shipwright"
          class="inline-flex h-8 items-center gap-1.5 rounded-[var(--radius-sm)] border px-3 transition hover:opacity-80"
          style="border-color:var(--border-strong);color:var(--fg-default)"
        >
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.9.57.1.78-.25.78-.55v-2.01c-3.2.7-3.87-1.37-3.87-1.37-.52-1.33-1.28-1.68-1.28-1.68-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.74.4-1.25.73-1.54-2.56-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.04 0 0 .97-.31 3.18 1.18.92-.26 1.91-.38 2.89-.39.98 0 1.97.13 2.89.39 2.21-1.5 3.18-1.18 3.18-1.18.63 1.58.23 2.75.11 3.04.74.81 1.19 1.84 1.19 3.1 0 4.42-2.69 5.4-5.25 5.69.41.36.78 1.06.78 2.13v3.16c0 .31.21.66.79.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/>
          </svg>
          shipwright (公开)
        </a>
        <span class="inline-flex h-8 items-center gap-1.5 rounded-[var(--radius-sm)] border px-3" style="border-color:var(--border-default);color:var(--fg-muted)">
          seomachine-cn (私有 · fork)
        </span>
        <span class="inline-flex h-8 items-center gap-1.5 rounded-[var(--radius-sm)] border px-3" style="border-color:var(--border-default);color:var(--fg-muted)">
          sku-starters (私有 · 核心资产)
        </span>
      </div>

      <!-- Timeline -->
      <ol class="relative border-l pl-0" style="border-color:var(--border-strong)">
        {entries.map((e) => (
          <li class="relative mb-10 pl-8">
            <span
              class="absolute left-0 top-2 inline-block h-3 w-3 -translate-x-1/2 rounded-full border-2"
              style="background:var(--bg-page);border-color:var(--color-signal-500)"
            ></span>

            <div class="mb-3 flex flex-wrap items-center gap-3">
              <time
                class="font-mono text-xs"
                style="color:var(--fg-muted)"
              >
                {e.date}
              </time>
              <span
                class="rounded-full px-2 py-0.5 font-mono text-[10px] font-bold uppercase tracking-[0.08em]"
                style={`background:${tagColors[e.tag] ?? 'var(--fg-muted)'}15;color:${tagColors[e.tag] ?? 'var(--fg-muted)'}`}
              >
                {e.tag}
              </span>
            </div>

            <h2 class="mb-3 text-lg font-semibold" style="color:var(--fg-display)">
              {e.title}
            </h2>

            <ul class="space-y-1.5 text-sm">
              {e.items.map((item) => (
                <li class="flex items-start gap-2" style="color:var(--fg-default)">
                  <span style="color:var(--color-signal-500)">•</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>

            {e.link && (
              <a
                href={e.link}
                class="mt-3 inline-flex items-center gap-1 font-mono text-xs underline decoration-dotted underline-offset-2"
                style="color:var(--fg-muted)"
              >
                git commit →
              </a>
            )}
          </li>
        ))}
      </ol>
    </section>

    <FinalCTA />
  </main>

  <SiteFooter />
</BaseLayout>
