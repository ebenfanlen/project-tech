---
import "../styles/global.css";
import ChatWidget from "../components/ChatWidget.astro";

export interface Props {
  title: string;
  description?: string;
  lang?: "zh-CN" | "zh-TW" | "en";
  path?: string;
  ogImage?: string;
}

const {
  title,
  description = "Shipwright / 船匠 — 跨境电商 DTC 的 AI 工作流定制团队。14 天交付，代码 100% 归你。",
  lang = "zh-CN",
  path = "/",
  ogImage = "/og-default.png",
} = Astro.props;

const siteUrl = "https://shipwright.co";
const canonical = `${siteUrl}${path}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- 三语 hreflang（Phase 1 预留标签，Phase 2 内容补齐） -->
    <link rel="alternate" hreflang="zh-CN" href={`${siteUrl}${path}`} />
    <link rel="alternate" hreflang="zh-TW" href={`${siteUrl}/zh-tw${path}`} />
    <link rel="alternate" hreflang="en" href={`${siteUrl}/en${path}`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${path}`} />

    <!-- 百度 专属 meta -->
    <meta name="applicable-device" content="pc,mobile" />
    <meta name="MobileOptimized" content="width" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Theme color（跟随浅/深） -->
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#FDFCF9" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0E2230" />

    <!-- OG / 社交 -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta
      property="og:locale"
      content={lang === "zh-CN" ? "zh_CN" : lang === "zh-TW" ? "zh_TW" : "en_US"}
    />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- 初始化 theme（防 FOUC，inline + 三态） -->
    <script is:inline>
      (() => {
        const saved = localStorage.getItem("theme-mode") || "system";
        const system = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const effective = saved === "system" ? (system ? "dark" : "light") : saved;
        document.documentElement.dataset.theme = effective;
        document.documentElement.dataset.themeMode = saved;

        // 监听系统切换（仅 mode=system 时响应）
        window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", (e) => {
          if (document.documentElement.dataset.themeMode === "system") {
            document.documentElement.dataset.theme = e.matches ? "dark" : "light";
          }
        });
      })();
    </script>
  </head>
  <body>
    <slot />

    <!-- Chat Widget (全站, /contact 自动不弹主动 tip) -->
    <ChatWidget />

    <!-- pangu 中英自动空格 (客户端增强) -->
    <script>
      import pangu from "pangu";
      // 页面加载后自动空格，并监听 DOM 变化（Island 等）
      pangu.autoSpacingPage();
    </script>
  </body>
</html>
