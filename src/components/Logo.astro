---
// AiOars · brand lockup
// mark: 圆角方括号 (rounded-square bracket · 对应 /public/brand/aioars-logo.png 主视觉元素)
// wordmark: "AiOars" + "船匠" 中文副标
// 保留 breathing prop 兼容旧签名 (现已无桅杆呼吸元素 · 可后续移除)
export interface Props {
  variant?: "full" | "mark" | "wordmark";
  size?: number;
  breathing?: boolean;
  class?: string;
}

const {
  variant = "full",
  size = 40,
  class: className = "",
} = Astro.props;
---

<span class:list={["inline-flex items-center gap-3", className]} aria-label="AiOars 船匠">
  {variant !== "wordmark" && (
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 48 48"
      width={size}
      height={size}
      fill="none"
      class="shrink-0"
      aria-hidden="true"
    >
      <rect
        x="5"
        y="5"
        width="38"
        height="38"
        rx="11"
        stroke="currentColor"
        stroke-width="4.5"
      />
    </svg>
  )}

  {variant !== "mark" && (
    <span class="flex flex-col leading-none">
      <span class="text-[1.125em] font-semibold tracking-tight">AiOars</span>
      <span
        class="mt-1 text-[0.55em] font-medium tracking-[0.3em]"
        style="color:var(--color-warm-500)"
      >
        船&nbsp;&nbsp;匠
      </span>
    </span>
  )}
</span>
