---
// 通用 SKU 详情页 · Vibecoding Pod / Fleet Integration / Crew Retainer 复用
import type { Sku } from "../data/skus";

export interface Props {
  sku: Sku;
  scenarios?: Array<{ tag: string; title: string; typical: string; result: string }>;
  upsellFrom?: Sku;         // 从上一 SKU 升级的路径
  upsellTo?: Sku;            // 下一 SKU 升级去向
  idealFor: string[];        // 什么时候该选这款
  notForYouIf: string[];     // 什么时候不该选
}

const { sku, scenarios, upsellFrom, upsellTo, idealFor, notForYouIf } = Astro.props;
const accentColor = sku.accentColor === "signal" ? "var(--color-signal-500)" : "var(--color-primary-500)";
const accentHover = sku.accentColor === "signal" ? "var(--color-signal-600)" : "var(--color-primary-600)";
---

<main>
  <!-- Hero -->
  <section class="mx-auto max-w-[1200px] px-6 pb-12 pt-16 sm:pt-24">
    <p
      class="mb-4 font-mono uppercase"
      style="font-size:var(--text-overline);letter-spacing:var(--text-overline--letter-spacing);color:{accentColor}"
    >
      {sku.nameEn} · {sku.nameZh}
    </p>
    <h1
      class="mb-4 font-semibold"
      style="font-size:clamp(2.25rem,6vw,3.75rem);line-height:1.1;letter-spacing:-0.02em;color:var(--fg-display)"
    >
      {sku.tagline}
    </h1>
    <p
      class="mb-10 max-w-2xl"
      style="font-size:var(--text-body-lg);color:var(--fg-default)"
    >
      {sku.subtitle}
    </p>

    <!-- 核心数字 + CTA -->
    <div
      class="grid gap-6 rounded-[var(--radius-lg)] border p-6 sm:grid-cols-[1.5fr_auto_auto] sm:items-center"
      style={`background:var(--bg-card);border-color:${accentColor};border-width:2px;box-shadow:var(--shadow-lg)`}
    >
      <div>
        <div
          class="tabular-nums font-bold"
          style="font-size:clamp(1.75rem,4vw,2.5rem);color:var(--fg-display)"
        >
          {sku.priceCN}
          <span class="ml-2 font-mono text-sm font-normal" style="color:var(--fg-muted)">
            / {sku.priceUS}
          </span>
        </div>
        <div class="mt-1 text-sm" style="color:var(--fg-muted)">
          {sku.duration}
          {sku.byokDiscount && (
            <>
              <span class="mx-2">·</span>
              <span class="font-mono font-semibold" style="color:var(--color-signal-600)">
                {sku.byokDiscount} BYOK
              </span>
            </>
          )}
        </div>
      </div>
      <a
        href={`/contact?sku=${sku.id}`}
        class="inline-flex h-12 items-center justify-center rounded-[var(--radius-md)] px-6 text-sm font-semibold transition hover:brightness-110"
        style={`background:${accentColor};color:var(--color-canvas-50);box-shadow:var(--shadow-sm)`}
      >
        {sku.cta}
      </a>
      <a
        href="/pricing"
        class="inline-flex h-12 items-center justify-center rounded-[var(--radius-md)] border px-4 text-sm font-medium transition hover:opacity-80"
        style="border-color:var(--border-strong);color:var(--fg-default)"
      >
        对比 4 SKU →
      </a>
    </div>

    <p class="mt-4 font-mono text-xs" style="color:var(--fg-muted)">
      目标客户: {sku.targetPersona}
    </p>
  </section>

  <!-- Problem / idealFor split -->
  <section
    class="border-y py-16"
    style="background:var(--bg-section);border-color:var(--border-default)"
  >
    <div class="mx-auto max-w-[1100px] px-6">
      <div class="grid gap-8 lg:grid-cols-2">
        <div>
          <p
            class="mb-3 font-mono uppercase"
            style="font-size:var(--text-overline);letter-spacing:var(--text-overline--letter-spacing);color:var(--color-success-700)"
          >
            ✓ 你应该选这款 · 如果...
          </p>
          <ul class="space-y-3">
            {idealFor.map((p) => (
              <li class="flex items-start gap-3 text-sm" style="color:var(--fg-default)">
                <svg
                  class="mt-1 h-4 w-4 shrink-0"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="var(--color-success-500)"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <span>{p}</span>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <p
            class="mb-3 font-mono uppercase"
            style="font-size:var(--text-overline);letter-spacing:var(--text-overline--letter-spacing);color:var(--fg-muted)"
          >
            ✗ 不适合你 · 如果...
          </p>
          <ul class="space-y-3">
            {notForYouIf.map((p) => (
              <li class="flex items-start gap-3 text-sm" style="color:var(--fg-muted)">
                <svg
                  class="mt-1 h-4 w-4 shrink-0"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <line x1="18" y1="6" x2="6" y2="18"></line>
                  <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
                <span>{p}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <p class="mt-8 text-sm" style="color:var(--fg-muted)">
        <strong style="color:var(--fg-display)">解决的核心问题:</strong> {sku.problem}
      </p>
    </div>
  </section>

  <!-- 5 个场景 (仅 Vibecoding Pod 等有 scenarios 的显示) -->
  {scenarios && scenarios.length > 0 && (
    <section class="mx-auto max-w-[1200px] px-6 py-20">
      <p
        class="mb-3 font-mono uppercase"
        style="font-size:var(--text-overline);letter-spacing:var(--text-overline--letter-spacing);color:{accentColor}"
      >
        5 scenes · pick one and ship
      </p>
      <h2
        class="mb-10 font-semibold"
        style="font-size:clamp(1.75rem,4vw,2.5rem);line-height:1.15;letter-spacing:-0.02em;color:var(--fg-display)"
      >
        5 个预置场景 · 14 天可交付的范围
      </h2>

      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-5">
        {scenarios.map((s, i) => (
          <div
            class="flex flex-col rounded-[var(--radius-lg)] border p-5"
            style="background:var(--bg-card);border-color:var(--border-default)"
          >
            <div class="mb-3 flex items-center justify-between">
              <span
                class="rounded-full px-2 py-0.5 font-mono text-[10px] font-bold uppercase tracking-[0.1em]"
                style="background:var(--color-primary-50);color:var(--color-primary-700)"
              >
                {s.tag}
              </span>
              <span class="font-mono text-[10px]" style="color:var(--fg-muted)">
                {String(i + 1).padStart(2, "0")}/05
              </span>
            </div>
            <h3 class="mb-3 text-base font-semibold" style="color:var(--fg-display)">
              {s.title}
            </h3>
            <p class="mb-3 flex-1 text-xs" style="color:var(--fg-muted)">
              <span class="font-mono uppercase tracking-[0.05em]">Before:</span> {s.typical}
            </p>
            <p class="text-xs" style="color:var(--color-success-700)">
              <span class="font-mono uppercase tracking-[0.05em]">After:</span> {s.result}
            </p>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- 完整交付清单 -->
  <section
    class="border-y py-16"
    style="background:var(--bg-section);border-color:var(--border-default)"
  >
    <div class="mx-auto max-w-[900px] px-6">
      <p
        class="mb-3 font-mono uppercase"
        style="font-size:var(--text-overline);letter-spacing:var(--text-overline--letter-spacing);color:{accentColor}"
      >
        What you get
      </p>
      <h2
        class="mb-8 font-semibold"
        style="font-size:clamp(1.5rem,3.5vw,2rem);line-height:1.15;color:var(--fg-display)"
      >
        完整交付清单
      </h2>

      <ol class="space-y-3">
        {sku.features.map((f, i) => (
          <li
            class="flex items-start gap-4 rounded-[var(--radius-md)] border p-4"
            style="background:var(--bg-card);border-color:var(--border-default)"
          >
            <span
              class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full font-mono text-xs font-bold"
              style={`background:${accentColor};color:var(--color-canvas-50)`}
            >
              {String(i + 1).padStart(2, "0")}
            </span>
            <span class="text-sm" style="color:var(--fg-default)">{f.text}</span>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Upsell path -->
  {(upsellFrom || upsellTo) && (
    <section class="mx-auto max-w-[1100px] px-6 py-16">
      <p
        class="mb-3 font-mono uppercase"
        style="font-size:var(--text-overline);letter-spacing:var(--text-overline--letter-spacing);color:{accentColor}"
      >
        Upgrade path
      </p>
      <h2
        class="mb-8 font-semibold"
        style="font-size:clamp(1.5rem,3.5vw,2rem);line-height:1.15;color:var(--fg-display)"
      >
        这款之前 / 之后
      </h2>

      <div class="grid gap-4 md:grid-cols-2">
        {upsellFrom && (
          <a
            href={upsellFrom.slug}
            class="flex flex-col rounded-[var(--radius-lg)] border p-6 transition hover:-translate-y-0.5"
            style="background:var(--bg-card);border-color:var(--border-default)"
          >
            <span
              class="mb-2 font-mono text-xs uppercase tracking-[0.08em]"
              style="color:var(--fg-muted)"
            >
              ← 上一款 · 如果还在犹豫
            </span>
            <h3 class="mb-1 text-lg font-semibold" style="color:var(--fg-display)">
              {upsellFrom.nameZh}
            </h3>
            <p class="mb-3 text-sm" style="color:var(--fg-default)">
              {upsellFrom.subtitle}
            </p>
            <div class="font-mono text-sm" style="color:var(--fg-muted)">
              {upsellFrom.priceCN} · {upsellFrom.duration}
            </div>
          </a>
        )}
        {upsellTo && (
          <a
            href={upsellTo.slug}
            class="flex flex-col rounded-[var(--radius-lg)] border p-6 transition hover:-translate-y-0.5"
            style={`background:var(--bg-card);border-color:${accentColor};border-width:2px`}
          >
            <span
              class="mb-2 font-mono text-xs uppercase tracking-[0.08em]"
              style="color:{accentColor}"
            >
              下一款 → 如果想更复杂
            </span>
            <h3 class="mb-1 text-lg font-semibold" style="color:var(--fg-display)">
              {upsellTo.nameZh}
            </h3>
            <p class="mb-3 text-sm" style="color:var(--fg-default)">
              {upsellTo.subtitle}
            </p>
            <div class="font-mono text-sm" style="color:var(--fg-muted)">
              {upsellTo.priceCN} · {upsellTo.duration}
            </div>
          </a>
        )}
      </div>
    </section>
  )}
</main>
