---
import { featuredCases } from "../data/cases";
---

<section class="mx-auto max-w-[1200px] px-6 py-20">
  <div class="mb-12 max-w-3xl">
    <p
      class="mb-3 font-mono uppercase"
      style="font-size:var(--text-overline);letter-spacing:var(--text-overline--letter-spacing);color:var(--color-signal-600)"
    >
      Proof over promise
    </p>
    <h2
      class="mb-4 font-semibold"
      style="font-size:clamp(1.75rem,4vw,2.5rem);line-height:1.15;letter-spacing:-0.02em;color:var(--fg-display)"
    >
      真客户 · 真数字 · 可复现
    </h2>
    <p style="font-size:var(--text-body-lg);color:var(--fg-default)">
      Phase 1 客户脱敏展示 · 每个案例含 before/after 量化指标 + 续约信号。
    </p>
  </div>

  <div class="grid gap-4 lg:grid-cols-3">
    {featuredCases.map((c) => (
      <a
        href={`/work/${c.slug}`}
        class="group flex flex-col rounded-[var(--radius-lg)] border p-6 transition hover:-translate-y-1"
        style="background:var(--bg-card);border-color:var(--border-default);box-shadow:var(--shadow-sm)"
      >
        <!-- Hook number (最大号) -->
        <div
          class="mb-4 font-semibold"
          style="font-size:clamp(1.25rem,2.5vw,1.625rem);line-height:1.2;color:var(--color-signal-600)"
        >
          {c.hook}
        </div>

        <div class="mb-4 flex flex-wrap items-center gap-2 text-[11px]">
          <span
            class="rounded-full px-2 py-0.5 font-mono"
            style="background:var(--bg-muted);color:var(--fg-default)"
          >
            {c.sku}
          </span>
          <span
            class="rounded-full px-2 py-0.5 font-mono"
            style="background:var(--color-primary-50);color:var(--color-primary-700)"
          >
            {c.scene}
          </span>
          <span style="color:var(--fg-muted)">·</span>
          <span style="color:var(--fg-muted)">{c.industry}</span>
        </div>

        <h3 class="mb-1 text-base font-semibold" style="color:var(--fg-display)">
          {c.clientHandle}
        </h3>
        <p class="mb-4 text-sm" style="color:var(--fg-muted)">
          {c.gmvBand}
        </p>

        <p class="mb-5 text-sm" style="color:var(--fg-default)">
          {c.problem}
        </p>

        <!-- 3 个 KPI -->
        <dl
          class="mb-5 grid grid-cols-3 gap-3 border-t pt-4 text-xs"
          style="border-color:var(--border-default)"
        >
          {c.kpis.map((k) => (
            <div>
              <dt
                class="mb-1 font-mono text-[10px] uppercase tracking-[0.05em]"
                style="color:var(--fg-muted)"
              >
                {k.label}
              </dt>
              <dd class="tabular-nums" style="color:var(--fg-display)">
                <span style="color:var(--fg-subtle)">{k.before}</span>
                <span style="color:var(--color-signal-500)" class="mx-1">→</span>
                <span class="font-semibold">{k.after}</span>
              </dd>
            </div>
          ))}
        </dl>

        {c.quote && (
          <blockquote
            class="mb-4 border-l-2 pl-3 text-sm italic"
            style="border-color:var(--color-signal-500);color:var(--fg-default)"
          >
            "{c.quote.text}"
            <footer
              class="mt-1 not-italic font-mono text-[11px]"
              style="color:var(--fg-muted)"
            >
              — {c.quote.attribution}
            </footer>
          </blockquote>
        )}

        {c.renewal && (
          <p
            class="mt-auto font-mono text-[11px]"
            style="color:var(--color-success-700)"
          >
            ✓ 续约: {c.renewal}
          </p>
        )}
      </a>
    ))}
  </div>

  <div class="mt-10 text-center">
    <a
      href="/work"
      class="inline-flex items-center gap-2 font-mono text-sm underline decoration-dotted underline-offset-4"
      style="color:var(--fg-default)"
    >
      查看全部案例 →
    </a>
  </div>
</section>
