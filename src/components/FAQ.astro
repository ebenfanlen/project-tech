---
import { homepageFaq } from "../data/faq";
---

<section
  class="border-y py-20"
  style="background:var(--bg-section);border-color:var(--border-default)"
>
  <div class="mx-auto max-w-[900px] px-6">
    <div class="mb-12 max-w-2xl">
      <p
        class="mb-3 font-mono uppercase"
        style="font-size:var(--text-overline);letter-spacing:var(--text-overline--letter-spacing);color:var(--color-signal-600)"
      >
        FAQ
      </p>
      <h2
        class="mb-4 font-semibold"
        style="font-size:clamp(1.75rem,4vw,2.5rem);line-height:1.15;letter-spacing:-0.02em;color:var(--fg-display)"
      >
        你在签约前最想问的 8 个问题
      </h2>
    </div>

    <!-- Accordion (纯 HTML details/summary, 无 JS) -->
    <div class="space-y-2">
      {homepageFaq.map((item, i) => (
        <details
          class="group overflow-hidden rounded-[var(--radius-md)] border transition"
          style="background:var(--bg-card);border-color:var(--border-default)"
        >
          <summary
            class="flex cursor-pointer items-start justify-between gap-4 p-5 font-medium"
            style="color:var(--fg-display)"
          >
            <span class="flex items-start gap-3">
              <span
                class="font-mono text-[11px] tabular-nums"
                style="color:var(--fg-muted);min-width:1.5rem;margin-top:0.2rem"
              >
                {String(i + 1).padStart(2, "0")}
              </span>
              <span>{item.q}</span>
            </span>
            <svg
              class="mt-1 h-4 w-4 shrink-0 transition group-open:rotate-45"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              aria-hidden="true"
            >
              <path d="M12 5v14M5 12h14"></path>
            </svg>
          </summary>
          <div
            class="border-t px-5 pb-5 pt-4 text-sm leading-relaxed"
            style="border-color:var(--border-default);color:var(--fg-default)"
          >
            {item.a}
          </div>
        </details>
      ))}
    </div>

    <p class="mt-8 text-center text-sm" style="color:var(--fg-muted)">
      还有其他问题？
      <a href="/contact" style="color:var(--color-signal-600);font-weight:600">
        直接问我们 →
      </a>
    </p>
  </div>
</section>
