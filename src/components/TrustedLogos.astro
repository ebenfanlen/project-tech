---
// 客户信任墙 · Phase 1 占位 (真客户签约同意后替换)
// 注: 去掉 aspirational 计数 (12 品牌/34 agent/1840 小时) · 反 Stitch Taste "fabricated stats" ban
// 签约真客户后, 把 label 换成真品牌名 + 可选 logo · 计数用真数字

const clients = [
  { label: "[Brand #01 · 跨境美妆独立站]", handle: "月 GMV ¥80 万" },
  { label: "[Brand #02 · Amazon 家居]", handle: "月 GMV $120K" },
  { label: "[Brand #03 · 3C 跨境]", handle: "月 GMV $280K" },
  { label: "[Brand #04 · 茶饮出海]", handle: "TikTok + 小红书" },
  { label: "[Brand #05 · 工具 DTC]", handle: "欧洲独立站" },
  { label: "[Brand #06 · 灯饰]", handle: "Amazon 全站" },
  { label: "[Brand #07 · 鞋服]", handle: "Shopify Plus" },
  { label: "[Brand #08 · 母婴]", handle: "TikTok Shop" },
];
---

<section
  class="border-y"
  style="background:var(--bg-section);border-color:var(--border-default)"
>
  <div class="mx-auto max-w-[1200px] px-6 py-14">
    <p
      class="mb-8 font-mono uppercase"
      style="font-size:var(--text-overline);letter-spacing:var(--text-overline--letter-spacing);color:var(--fg-muted)"
    >
      Phase 1 · 首批合作品牌占位 (签约同意后替换真 logo)
    </p>

    <!-- 客户 label grid · asymmetric 左对齐 -->
    <ul class="grid grid-cols-2 gap-x-8 gap-y-4 sm:grid-cols-4">
      {clients.map((c) => (
        <li class="flex flex-col">
          <span
            class="text-sm font-medium"
            style="color:var(--fg-default)"
          >
            {c.label}
          </span>
          <span
            class="font-mono text-[11px]"
            style="color:var(--fg-subtle)"
          >
            {c.handle}
          </span>
        </li>
      ))}
    </ul>

    <!-- 诚实声明 (代替假数字) -->
    <p
      class="mt-10 max-w-2xl border-l-2 pl-4 text-sm"
      style="border-color:var(--color-signal-500);color:var(--fg-default);line-height:1.7"
    >
      <strong style="color:var(--fg-display)">诚实说明:</strong>
      AiOars 2026 年 4 月刚启动 · 前 3 个 Pilot Pod / Vibecoding Pod 客户正在对接.
      这里的 8 个品牌占位是客户画像 · 真实客户 logo 和案例会随交付完成陆续替换.
      反"fabricated stats" · 反"99.99% uptime" · 只放可验证的数字.
    </p>
  </div>
</section>
