---
// Hero 下方横向滚动场景 banner · 参考 CineStream "한국 미디어의 전부" 风格
// 5 大场景作 5 张大卡 · 中间卡 scale + glow · 两侧变淡
// 交互: 原生 overflow-x-auto + scroll-snap-x · 支持触摸拖动 + 滚轮 + 左右箭头按钮
import { scenes } from "../data/scenes";

// 为 5 个场景配不同 glow 色 (低饱和 · 夜空感)
const glows: Record<string, { from: string; color: string }> = {
  "v-cs": { from: "rgba(255,235,190,0.22)", color: "Pale Amber" },   // 客服 · 温暖
  "v-seo": { from: "rgba(130,220,160,0.22)", color: "Jade Forest" },  // SEO · 森绿 (对齐 CineStream NF 深绿)
  "v-ad": { from: "rgba(230,140,100,0.22)", color: "Ember Glow" },     // 广告 · 橙红
  "v-content": { from: "rgba(200,130,230,0.22)", color: "Orchid Dusk" },// 内容 · 紫
  "v-ops": { from: "rgba(130,180,230,0.22)", color: "Steel Blue" },     // 运营 · 蓝
};

// 场景简码 (大号字母 · 类参考图 AP / NF / DP)
const codeMap: Record<string, string> = {
  "v-cs": "CS",
  "v-seo": "SEO",
  "v-ad": "AD",
  "v-content": "CT",
  "v-ops": "OPS",
};
---

<section class="relative overflow-hidden py-16 sm:py-20" aria-label="5 大 Vibecoding 场景">
  <!-- 背景装饰: 星点网格 (CineStream 参考图里的星座感) -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 opacity-[0.08]"
    style="background-image: radial-gradient(circle, var(--accent) 1px, transparent 1px); background-size: 48px 48px;"
  ></div>

  <!-- Section 头 -->
  <div class="relative mx-auto mb-10 max-w-[1200px] px-6 text-center">
    <p
      class="mb-4 font-mono uppercase"
      style="font-size:var(--text-overline);letter-spacing:var(--text-overline--letter-spacing);color:var(--accent)"
    >
      5 Scenes · Pick one & ship in 14 days
    </p>
    <h2
      class="mb-3 font-bold"
      style="font-size:clamp(2rem,4vw,3rem);line-height:1.15;letter-spacing:-0.02em;color:var(--fg-display)"
    >
      跨境电商 AI 工作流 · 5 个场景全覆盖
    </h2>
    <p class="mx-auto max-w-2xl text-base" style="color:var(--fg-muted)">
      客服 · Listing · 广告 · 内容 · 运营 — Vibecoding Pod 14 天就能交付其中任意一个场景
    </p>
  </div>

  <!-- 卡片轮播 · 横向 scroll-snap -->
  <div
    class="relative mx-auto max-w-[1400px]"
    data-carousel
  >
    <!-- 左右按钮 · 绝对定位 -->
    <button
      type="button"
      data-scroll="prev"
      aria-label="上一个"
      class="absolute left-4 top-1/2 z-20 hidden h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full border backdrop-blur-md transition hover:scale-105 md:inline-flex"
      style="background:rgba(27,27,27,0.72);border-color:var(--border-strong);color:var(--fg-display)"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>
    <button
      type="button"
      data-scroll="next"
      aria-label="下一个"
      class="absolute right-4 top-1/2 z-20 hidden h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full border backdrop-blur-md transition hover:scale-105 md:inline-flex"
      style="background:rgba(27,27,27,0.72);border-color:var(--border-strong);color:var(--fg-display)"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>

    <!-- 渐淡边缘 mask · 左右 fade -->
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-y-0 left-0 z-10 w-20 md:w-32"
      style="background:linear-gradient(to right, var(--bg-page) 0%, transparent 100%)"
    ></div>
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-y-0 right-0 z-10 w-20 md:w-32"
      style="background:linear-gradient(to left, var(--bg-page) 0%, transparent 100%)"
    ></div>

    <!-- 可滚容器 -->
    <ul
      class="scene-scroller flex snap-x snap-mandatory gap-4 overflow-x-auto px-[calc(50vw-180px)] pb-8 pt-4 md:gap-6 md:px-[calc(50%-220px)]"
      style="scrollbar-width:none"
      data-track
    >
      {scenes.map((s, i) => {
        const glow = glows[s.code] ?? glows["v-cs"];
        const code = codeMap[s.code] ?? s.code.toUpperCase();
        return (
          <li class="snap-center shrink-0">
            <a
              href={`/scenes/${s.code}`}
              class="scene-card group relative block overflow-hidden rounded-[var(--radius-3xl)] border transition-all duration-500"
              style={`background:var(--bg-card);border-color:var(--border-default);width:clamp(260px, 32vw, 380px);aspect-ratio: 3 / 4;`}
            >
              <!-- 顶部 glow (类参考图 NF 的绿色 radial gradient) -->
              <div
                aria-hidden="true"
                class="pointer-events-none absolute inset-x-0 top-0 h-[55%]"
                style={`background:radial-gradient(ellipse 80% 60% at 50% 0%, ${glow.from} 0%, transparent 65%)`}
              ></div>

              <!-- 右上角编号 pill · "01" / "02" etc -->
              <span
                class="absolute right-5 top-5 z-10 inline-flex h-7 min-w-7 items-center justify-center rounded-full px-2 font-mono text-xs font-semibold tabular-nums"
                style="background:var(--bg-muted);color:var(--accent);font-variant-numeric:tabular-nums slashed-zero"
              >
                {String(i + 1).padStart(2, "0")}
              </span>

              <!-- 中心大号字母代号 -->
              <div class="absolute inset-0 flex items-center justify-center">
                <span
                  class="select-none font-black tracking-tighter transition-transform duration-500 group-hover:scale-105"
                  style="font-size:clamp(4rem, 10vw, 7rem);color:var(--fg-display);line-height:0.9;letter-spacing:-0.04em"
                >
                  {code}
                </span>
              </div>

              <!-- 底部 label -->
              <div class="absolute inset-x-0 bottom-0 p-6">
                <h3
                  class="mb-1 text-lg font-semibold"
                  style="color:var(--fg-display)"
                >
                  {s.title.split(" · ")[1] ?? s.title}
                </h3>
                <p class="text-sm" style="color:var(--fg-muted);line-height:1.5">
                  {s.hook.length > 40 ? s.hook.slice(0, 40) + "…" : s.hook}
                </p>
                <!-- KPI 高亮一条 -->
                <p class="mt-3 font-mono text-xs" style="color:var(--accent)">
                  {s.kpis[0].label}: {s.kpis[0].before} → <strong>{s.kpis[0].after}</strong>
                </p>
              </div>

              <!-- 微妙 vignette 下缘暗角 -->
              <div
                aria-hidden="true"
                class="pointer-events-none absolute inset-x-0 bottom-0 h-1/3"
                style="background:linear-gradient(to top, rgba(0,0,0,0.4), transparent)"
              ></div>
            </a>
          </li>
        );
      })}
    </ul>

    <!-- scroll indicator dots -->
    <div class="mt-4 flex justify-center gap-1.5" data-indicators>
      {scenes.map((_, i) => (
        <button
          type="button"
          data-dot={i}
          aria-label={`跳到第 ${i + 1} 张`}
          class="h-1.5 rounded-full transition-all duration-300"
          style={i === 0
            ? "width:24px;background:var(--accent)"
            : "width:8px;background:var(--bg-muted)"}
        ></button>
      ))}
    </div>
  </div>
</section>

<style>
  .scene-scroller::-webkit-scrollbar { display: none; }

  /* 非中心卡片视觉淡化 (scroll-snap 居中 + opacity transition) */
  .scene-card {
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
  }

  .scene-card:hover {
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.45), 0 0 0 1px var(--accent);
  }

  @media (prefers-reduced-motion: reduce) {
    .scene-card { transition: none !important; }
  }
</style>

<script is:inline>
(() => {
  const carousel = document.querySelector("[data-carousel]");
  if (!carousel) return;
  const track = carousel.querySelector("[data-track]");
  const prev = carousel.querySelector("[data-scroll='prev']");
  const next = carousel.querySelector("[data-scroll='next']");
  const dots = carousel.querySelectorAll("[data-dot]");
  if (!track) return;

  const cards = track.querySelectorAll("li");
  const cardWidth = () => cards[0]?.getBoundingClientRect().width + 16 || 400;

  prev?.addEventListener("click", () => track.scrollBy({ left: -cardWidth(), behavior: "smooth" }));
  next?.addEventListener("click", () => track.scrollBy({ left: cardWidth(), behavior: "smooth" }));

  dots.forEach((dot) => {
    dot.addEventListener("click", () => {
      const i = parseInt(dot.dataset.dot, 10);
      const card = cards[i];
      if (card) card.scrollIntoView({ behavior: "smooth", inline: "center", block: "nearest" });
    });
  });

  // 更新 dot active 状态 + 中心卡片放大
  const updateActive = () => {
    const trackRect = track.getBoundingClientRect();
    const trackCenter = trackRect.left + trackRect.width / 2;
    let closest = 0, minDist = Infinity;
    cards.forEach((card, i) => {
      const rect = card.getBoundingClientRect();
      const center = rect.left + rect.width / 2;
      const dist = Math.abs(center - trackCenter);
      if (dist < minDist) { minDist = dist; closest = i; }

      // 两侧卡片淡化
      const norm = Math.min(dist / trackRect.width, 1);
      const card0 = card.querySelector(".scene-card");
      if (card0) {
        card0.style.opacity = String(1 - norm * 0.5);
        card0.style.transform = `scale(${1 - norm * 0.08})`;
      }
    });

    dots.forEach((dot, i) => {
      const active = i === closest;
      dot.style.width = active ? "24px" : "8px";
      dot.style.background = active ? "var(--accent)" : "var(--bg-muted)";
    });
  };

  track.addEventListener("scroll", () => requestAnimationFrame(updateActive), { passive: true });
  window.addEventListener("resize", updateActive);
  setTimeout(updateActive, 100);
})();
</script>
