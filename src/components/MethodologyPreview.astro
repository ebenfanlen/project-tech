---
import { methodology } from "../data/methodology";

// 首页预览只显示 6 个关键节点（D1/D3/D7/D10/D13/D14）
const highlights = methodology.filter((m) =>
  [1, 3, 7, 10, 13, 14].includes(m.day as number)
);
---

<section
  class="border-y py-20"
  style="background:var(--bg-section);border-color:var(--border-default)"
>
  <div class="mx-auto max-w-[1200px] px-6">
    <div class="mb-12 flex flex-wrap items-end justify-between gap-4">
      <div class="max-w-2xl">
        <p
          class="mb-3 font-mono uppercase"
          style="font-size:var(--text-overline);letter-spacing:var(--text-overline--letter-spacing);color:var(--color-signal-600)"
        >
          How we ship · 14 days, 14 deliverables
        </p>
        <h2
          class="mb-4 font-semibold"
          style="font-size:clamp(1.75rem,4vw,2.5rem);line-height:1.15;letter-spacing:-0.02em;color:var(--fg-display)"
        >
          Day by Day · 每天一个可验收产物
        </h2>
        <p style="font-size:var(--text-body-lg);color:var(--fg-default)">
          不是 4-8 周的黑盒外包。每天有明确产物 · 每晚有 stand-up · Day 7 是 go/no-go 决策点。
          超期按 3% setup/天退款，最高退 30%。
        </p>
      </div>
      <a
        href="/how"
        class="inline-flex items-center gap-2 font-mono text-sm underline decoration-dotted underline-offset-4"
        style="color:var(--fg-default)"
      >
        看完整 14 天方法论 →
      </a>
    </div>

    <!-- 横向 Timeline (desktop) / 垂直 (mobile) -->
    <ol class="relative grid gap-6 md:grid-cols-6">
      <!-- 连接线 (desktop only) -->
      <div
        class="absolute left-4 right-4 top-[14px] hidden h-px md:block"
        style="background:var(--border-strong)"
        aria-hidden="true"
      ></div>

      {highlights.map((step, i) => {
        const isLast = i === highlights.length - 1;
        const isCritical = step.day === 7 || step.day === 14;
        return (
          <li class="relative">
            <div class="mb-3 flex items-center gap-3 md:mb-4">
              <span
                class="relative inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full font-mono text-[11px] font-bold"
                style={
                  isCritical
                    ? "background:var(--color-signal-500);color:var(--color-canvas-50);box-shadow:0 0 0 4px rgba(232,106,42,0.15)"
                    : "background:var(--color-primary-500);color:var(--color-canvas-50)"
                }
              >
                {step.phaseEn}
              </span>
              <span
                class="font-mono text-[10px] uppercase tracking-[0.08em] md:hidden"
                style="color:var(--fg-muted)"
              >
                Day {step.day}
              </span>
            </div>
            <h3
              class="mb-1 text-sm font-semibold"
              style="color:var(--fg-display)"
            >
              {step.phase}
            </h3>
            <p class="text-xs" style="color:var(--fg-muted)">
              {step.deliverable.split(" (")[0]}
            </p>
          </li>
        );
      })}
    </ol>

    <!-- 为什么能做到 -->
    <div
      class="mt-12 grid gap-4 rounded-[var(--radius-lg)] border p-6 md:grid-cols-3"
      style="background:var(--bg-card);border-color:var(--border-default)"
    >
      <div>
        <p
          class="mb-2 font-mono text-xs uppercase tracking-[0.08em]"
          style="color:var(--color-signal-600)"
        >
          01 · Follow the sun
        </p>
        <p class="text-sm" style="color:var(--fg-default)">
          北京早班 + 深圳 / 东南亚晚班 = <strong style="color:var(--fg-display)">16h/天</strong>
          · 美西客户睡一觉醒来看到 async 响应
        </p>
      </div>
      <div>
        <p
          class="mb-2 font-mono text-xs uppercase tracking-[0.08em]"
          style="color:var(--color-signal-600)"
        >
          02 · Claude Code ×3 productivity
        </p>
        <p class="text-sm" style="color:var(--fg-default)">
          内部 benchmark：一个全栈 + Claude Code ≈
          <strong style="color:var(--fg-display)">3 个传统工程师</strong> · SKU-02 代码量 3K-8K 行，5-7 天出首版
        </p>
      </div>
      <div>
        <p
          class="mb-2 font-mono text-xs uppercase tracking-[0.08em]"
          style="color:var(--color-signal-600)"
        >
          03 · 5 大场景 starter kits
        </p>
        <p class="text-sm" style="color:var(--fg-default)">
          V-CS / V-SEO / V-AD / V-CONTENT / V-OPS 各有预置 Agent 架构 + API 集成 + Prompt 库
          · 每单 <strong style="color:var(--fg-display)">70% 模板化</strong>
        </p>
      </div>
    </div>
  </div>
</section>
