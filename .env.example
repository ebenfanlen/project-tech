# Shipwright · 环境变量模板
# 复制本文件为 .env.local (dev) 或 配置到 GitHub Secrets (prod)
# 所有 PUBLIC_ 前缀的变量会注入到客户端 · 小心暴露

# === 分析埋点 (Week 2 启用) ===
PUBLIC_BAIDU_TONGJI_ID=              # 百度统计 ID · 国内主埋点
PUBLIC_PLAUSIBLE_DOMAIN=             # Plausible domain (shipwright.co) · 海外隐私友好
PUBLIC_SENTRY_DSN=                   # Sentry DSN · 错误监控 (国内外通用)

# === 部署 (Week 1 D6 CI/CD 启用) ===
CLOUDFLARE_API_TOKEN=                # CF Pages 部署 token
CLOUDFLARE_ACCOUNT_ID=               # CF 账号 ID
ALIYUN_ACCESS_KEY_ID=                # 阿里云 OSS/CDN/FC 部署
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_OSS_BUCKET=shipwright-prod
ALIYUN_OSS_REGION=cn-hangzhou
ALIYUN_CDN_DOMAIN=shipwright.cn

# === SEO 自动化 (Week 3 SEOMachine fork 启用) ===
BAIDU_PUSH_TOKEN=                    # 百度站长平台 → 数据提交 → 主动推送 token
5118_API_KEY=                        # 5118 会员 API · 国内长尾 KW + 百度指数
DATAFORSEO_LOGIN=                    # (可选) 海外对标 KW 研究
DATAFORSEO_PASSWORD=

# === 通知 (Week 2 Chat Widget 真后端) ===
DEPLOY_WEBHOOK_URL=                  # 飞书机器人 webhook · 部署/lead/故障通知
LEAD_WEBHOOK_URL=                    # 新 lead 来临的飞书卡片通知

# === 后端 (Week 2 Day 10-11 启用) ===
DATABASE_URL=                        # 阿里云 RDS Postgres 连接串
ANTHROPIC_API_KEY=                   # Chat Widget 真 AI 回复 (Claude Haiku)
AUTH_SECRET=                         # Auth.js magic link 加密密钥
AUTH_EMAIL_FROM=hello@shipwright.co  # 发件人

# === 一稿多投 (Week 4 启用) ===
BAIJIAHAO_APP_ID=                    # 百度百家号机构号 (自动发布)
BAIJIAHAO_APP_SECRET=
SOHU_ACCESS_TOKEN=                   # 搜狐号 (自动发布)
WECHAT_APP_ID=                       # 公众号 (自动发草稿, 人工定时发)
WECHAT_APP_SECRET=
